<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1" name="viewport"/>
<meta content="Choose a language for the eMule broadband edition website." name="description"/>
<meta content="index,follow" name="robots"/>
<meta content="eMulebb" name="author"/>
<meta content="Languages | eMule broadband edition" property="og:title"/>
<meta content="Choose a localized eMule BB website page." property="og:description"/>
<meta content="website" property="og:type"/>
<meta content="{{ page.url }}" property="og:url"/>
<meta content="summary" name="twitter:card"/>
<link href="{{ page.url }}" rel="canonical"/>
<link href="{{ site_base_url }}/sitemap.xml" rel="sitemap" type="application/xml"/>
{%- for alternate in alternates %}
<link href="{{ alternate.url }}" hreflang="{{ alternate.hreflang }}" rel="alternate"/>
{%- endfor %}
<title>Languages | eMule broadband edition</title>
<link href="{{ pico_cdn }}" rel="stylesheet"/>
<link href="../styles.css" rel="stylesheet"/>
<script async src="https://www.googletagmanager.com/gtag/js?id={{ ga_measurement_id }}"></script>
<script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());

      gtag('config', '{{ ga_measurement_id }}');
    </script>
</head>
<body>
<main class="language-page">
<section class="section language-hero">
<p class="eyebrow">Languages</p>
<h1>Choose your eMule BB language</h1>
<p class="lead">English is the master page. Localized pages keep the same product facts, release status, and technical terms.</p>
<div class="actions">
<a class="button secondary" href="../">Back to English</a>
</div>
</section>
<section class="section">
<div class="language-groups">
{%- for group in groups %}
<article>
<h2>{{ group.label }}</h2>
<div class="language-list">
{%- for link in group.links %}
<a href="{{ link.href }}" hreflang="{{ link.hreflang }}">{{ link.label }}</a>
{%- endfor %}
</div>
</article>
{%- endfor %}
</div>
</section>
</main>
</body>
</html>
